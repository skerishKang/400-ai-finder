{
  "schema_version": "1.0.0",
  "track": "1109-page-agent-comparison",
  "description": "Mode-specific expected routes and action sequences for the 5 parity scenarios. Shared pass criteria are defined in parity-contract.json and are NOT duplicated here.",
  "scenarios": [
    {
      "id": "apartment_contact",
      "deterministic": {
        "trigger": "housing_department",
        "expected_final_route": "home",
        "expected_journey_id": "apartment-dept",
        "expected_action_sequence": [
          "click_element_by_index",
          "click_element_by_index",
          "type",
          "click_element_by_index"
        ],
        "expected_final_state": "done"
      },
      "page_agent": {
        "trigger": "공동주택과 연락처 찾아줘",
        "expected_final_route": "apartment-dept",
        "expected_action_sequence": ["click_element_by_index", "done"],
        "expected_nav_steps": 1,
        "expected_call_count": 2
      }
    },
    {
      "id": "bulky_waste_menu",
      "deterministic": {
        "trigger": "bulky_waste",
        "expected_final_route": "bulky-waste-disposal",
        "expected_journey_id": "bulky-waste-disposal-guidance",
        "expected_action_sequence": [
          "route",
          "target"
        ],
        "expected_final_state": "done"
      },
      "page_agent": {
        "trigger": "대형폐기물 신청 메뉴 찾아줘",
        "expected_final_route": "bulky-waste-disposal",
        "expected_action_sequence": ["click_element_by_index", "done"],
        "expected_nav_steps": 1,
        "expected_call_count": 2
      }
    },
    {
      "id": "passport_procedure",
      "deterministic": {
        "trigger": "passport_guidance",
        "expected_final_route": "passport-guidance",
        "expected_journey_id": "passport-guidance",
        "expected_action_sequence": [
          "target",
          "route",
          "route",
          "target"
        ],
        "expected_final_state": "done"
      },
      "page_agent": {
        "trigger": "여권 발급 절차를 찾아줘",
        "expected_final_route": "passport-guidance",
        "expected_action_sequence": ["click_element_by_index", "done"],
        "expected_nav_steps": 1,
        "expected_call_count": 2
      }
    },
    {
      "id": "complaint_screen",
      "deterministic": {
        "trigger": "streetlight_report",
        "expected_final_route": "complaint-write",
        "expected_journey_id": "complaint-board-write",
        "expected_action_sequence": [
          "route",
          "route",
          "click",
          "type",
          "type_content",
          "confirmation"
        ],
        "expected_final_state": "waiting_confirmation",
        "note": "Deterministic mode uses streetlight_report as the closest complaint-writing journey. No exact form_assist-scoped journey exists."
      },
      "page_agent": {
        "trigger": "민원 작성 화면을 열어줘",
        "expected_final_route": "complaint-write",
        "expected_action_sequence": ["click_element_by_index", "click_element_by_index", "done"],
        "expected_nav_steps": 2,
        "expected_call_count": 3
      }
    },
    {
      "id": "mayor_proposal_writing",
      "deterministic": {
        "trigger": "mayor_message_assist",
        "expected_final_route": "mayor-complaint-write",
        "expected_journey_id": "mayor-message-assist",
        "expected_action_sequence": [
          "type_title",
          "type_content",
          "confirmation"
        ],
        "expected_final_state": "waiting_confirmation"
      },
      "page_agent": {
        "trigger": "구청장에게 제안할 글 작성을 도와줘",
        "expected_final_route": "mayor-complaint-write",
        "expected_action_sequence": ["click_element_by_index", "click_element_by_index", "done"],
        "expected_nav_steps": 2,
        "expected_call_count": 3
      }
    }
  ],
  "boundary": {
    "unsupported": {
      "trigger": "오늘 날씨 알려줘",
      "deterministic_detection": "hasJourney returns false",
      "page_agent_detection": "mock model responds with done/success=false",
      "expected": "safe terminal response, no unrelated route, no external request, no submit"
    },
    "cancellation": {
      "note": "Cancellation testing depends on mode-specific UI availability. If not exposed, record as not_exposed.",
      "deterministic_cancel_method": "CitizenFirstChoreography.cancel()",
      "page_agent_cancel_method": "#chat-cancel button click",
      "expected": "terminal cancelled or safe interrupted state"
    }
  }
}

# =============================================================================
# 400-ai-finder — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- LLM Provider Configuration ---
# Supported values: mock, stub, opencode-go, opengateway, nvidia, kilocode,
#                   mistral, groq, opencode-zen, nous
AI_FINDER_LLM_PROVIDER=mock

# --- Mock Provider ---
AI_FINDER_MOCK_RESPONSE=이것은 mock provider 응답입니다.

# --- Stub Provider ---
# Generates source-based simulated responses. No API key required.
# AI_FINDER_LLM_PROVIDER=stub

# --- OpenCode-Go ---
# https://github.com/nousresearch/opencode-go
# OPENCODE_GO_API_KEY=your-opencode-go-api-key
# OPENCODE_GO_BASE_URL=https://api.opencode-go.com/v1

# --- Mistral AI ---
# https://console.mistral.ai/
# MISTRAL_API_KEY=your-mistral-api-key

# --- OpenGateway / OpenCodeGo ---
# OPENGATEWAY_API_KEY=your-opengateway-api-key

# --- KiloCode ---
# https://kilo.app/
# KILOCODE_API_KEY=your-kilocode-api-key

# --- NVIDIA NIM ---
# https://build.nvidia.com/
# NVIDIA_API_KEY=your-nvidia-api-key

# --- Groq ---
# https://console.groq.com/
# GROQ_API_KEY=your-groq-api-key

# --- OpenCode-Zen ---
# https://github.com/nousresearch/opencode-zen
# OPENCODE_ZEN_API_KEY=your-opencode-zen-api-key
# OPENCODE_ZEN_BASE_URL=https://api.opencode-zen.com/v1

# --- Nous Research ---
# https://github.com/nousresearch/nous
# NOUS_API_KEY=your-nous-api-key
# NOUS_BASE_URL=https://api.nousresearch.com/v1

# =============================================================================
# Fetch Provider Configuration
# =============================================================================
# Supported values: mock, requests, firecrawl
AI_FINDER_FETCH_PROVIDER=requests

# --- Mock Fetch Provider ---
AI_FINDER_FETCH_MOCK_MARKDOWN=이것은 mock fetch markdown입니다.
AI_FINDER_FETCH_MOCK_HTML=<html><head><title>Mock Page</title></head><body>Mock body</body></html>
AI_FINDER_FETCH_MOCK_TITLE=Mock Page

# --- Firecrawl Fetch Provider ---
# https://www.firecrawl.dev/
FIRECRAWL_BASE_URL=https://api.firecrawl.dev
FIRECRAWL_API_KEY=replace-with-your-firecrawl-api-key
FIRECRAWL_TIMEOUT=60

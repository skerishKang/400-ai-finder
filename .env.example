# =============================================================================
# 400-ai-finder — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- LLM Provider Configuration ---
# Supported values: mock, openai_compatible, mistral, opengateway, kilocode,
#                   nvidia, groq
AI_FINDER_LLM_PROVIDER=mock

# --- Mock Provider ---
AI_FINDER_MOCK_RESPONSE=이것은 mock provider 응답입니다.

# --- Generic OpenAI-Compatible Provider ---
# Works with any OpenAI-compatible API endpoint.
AI_FINDER_LLM_BASE_URL=https://api.openai.com/v1
AI_FINDER_LLM_API_KEY=replace-with-your-api-key
AI_FINDER_LLM_MODEL=gpt-4o-mini
AI_FINDER_LLM_TIMEOUT=60
AI_FINDER_LLM_TEMPERATURE=0.2
AI_FINDER_LLM_MAX_TOKENS=1200

# --- Mistral AI ---
# https://console.mistral.ai/
# MISTRAL_API_KEY=your-mistral-api-key

# --- OpenGateway / OpenCodeGo ---
# OPENGATEWAY_API_KEY=your-opengateway-api-key

# --- KiloCode ---
# https://kilo.app/
# KILOCODE_API_KEY=your-kilocode-api-key

# --- NVIDIA NIM ---
# https://build.nvidia.com/
# NVIDIA_API_KEY=your-nvidia-api-key

# --- Groq ---
# https://console.groq.com/
# GROQ_API_KEY=your-groq-api-key
